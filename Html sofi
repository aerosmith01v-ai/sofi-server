<script>
// ══════════════════════════════════════════════════════════════
// CONFIGURACIÓN
// ══════════════════════════════════════════════════════════════
const BASE = window.location.origin; // usa el mismo servidor
let API_KEY = localStorage.getItem('sofi_key') || 'sofi-dev-2026';
let modoOnline = false;

// ══════════════════════════════════════════════════════════════
// UTILIDADES
// ══════════════════════════════════════════════════════════════
function headers() {
  return { 'Content-Type':'application/json', 'x-sofi-key': API_KEY };
}

async function api(endpoint, metodo = 'GET', body = null) {
  const opts = { method: metodo, headers: headers() };
  if (body) opts.body = JSON.stringify(body);
  const res = await fetch(BASE + endpoint, opts);
  return res;
}

function autoResize(el) {
  el.style.height = 'auto';
  el.style.height = Math.min(el.scrollHeight, 120) + 'px';
}

// ══════════════════════════════════════════════════════════════
// NAVEGACIÓN
// ══════════════════════════════════════════════════════════════
function cambiarPanel(id, btn) {
  document.querySelectorAll('.panel').forEach(p => p.classList.remove('activo'));
  document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('activo'));
  document.getElementById('panel-' + id).classList.add('activo');
  btn.classList.add('activo');
  if (id === 'config') cargarStats();
}

// ══════════════════════════════════════════════════════════════
// HEALTH CHECK
// ══════════════════════════════════════════════════════════════
async function checkHealth() {
  try {
    const res = await fetch(BASE + '/health');
    const d   = await res.json();
    document.getElementById('statusDot').style.background = 'var(--success)';
    document.getElementById('cfgStatus').textContent  = 'online ✓';
    document.getElementById('cfgVersion').textContent = d.version || '—';
    modoOnline = d.modo_online || false;
    document.getElementById('cfgModo').textContent = modoOnline ? 'ON' : 'OFF';
    document.getElementById('toggleOnline').classList.toggle('on', modoOnline);
  } catch {
    document.getElementById('statusDot').style.background = '#ff0066';
    document.getElementById('cfgStatus').textContent = 'offline ✗';
  }
}

async function cargarStats() {
  try {
    const res = await fetch(BASE + '/health');
    const d   = await res.json();
    document.getElementById('statConoc').textContent = d.conocimiento  ?? 0;
    document.getElementById('statInter').textContent = d.interacciones ?? 0;
    document.getElementById('statNotas').textContent = d.notas         ?? 0;
    document.getElementById('statBusq').textContent  = d.busquedas     ?? 0;
  } catch {}
}

// ══════════════════════════════════════════════════════════════
// CHAT
// ══════════════════════════════════════════════════════════════
function agregarMensaje(texto, tipo) {
  const box = document.getElementById('chatBox');
  const div = document.createElement('div');
  div.className = 'msg ' + tipo;
  if (tipo === 'sofi') {
    div.innerHTML = `<div class="msg-header">SOFI ·</div>${texto}`;
  } else {
    div.textContent = texto;
  }
  box.appendChild(div);
  box.scrollTop = box.scrollHeight;
}

async function enviarChat() {
  const input = document.getElementById('chatInput');
  const txt   = input.value.trim();
  if (!txt) return;

  input.value = ''; input.style.height = 'auto';
  document.getElementById('sendBtn').disabled = true;
  agregarMensaje(txt, 'user');

  const typing = document.getElementById('typing');
  typing.classList.add('visible');
  document.getElementById('chatBox').scrollTop = 99999;

  try {
    const res = await api('/chat', 'POST', { pregunta: txt });
    const d   = await res.json();
    typing.classList.remove('visible');
    if (d.respuesta) {
      agregarMensaje(d.respuesta + (d.nivel ? `\n\n<span style="font-size:.7rem;opacity:.4">nivel: ${d.nivel}</span>` : ''), 'sofi');
    } else if (d.error) {
      agregarMensaje('⚠️ ' + d.error, 'error');
    }
  } catch (e) {
    typing.classList.remove('visible');
    agregarMensaje('Sin conexión con SOFI. Verifica tu API key.', 'error');
  }

  document.getElementById('sendBtn').disabled = false;
}

// ══════════════════════════════════════════════════════════════
// BÚSQUEDA
// ══════════════════════════════════════════════════════════════
async function buscar() {
  const query = document.getElementById('buscarQuery').value.trim();
  if (!query) return;
  const res_el = document.getElementById('buscarResultado');
  res_el.className = 'resultado visible';
  res_el.innerHTML = '<span class="loader"></span> Buscando...';

  try {
    const res = await api('/buscar', 'POST', { query });
    const d   = await res.json();
    if (d.ok && d.resultados?.length) {
      let txt = '';
      d.resultados.forEach(r => {
        txt += `[${r.fuente.toUpperCase()}]\n${r.titulo ? r.titulo + '\n' : ''}${r.resumen}\n\n`;
      });
      res_el.className = 'resultado visible ok';
      res_el.textContent = txt.trim();
    } else {
      res_el.className = 'resultado visible';
      res_el.textContent = 'Sin resultados para: ' + query;
    }
  } catch {
    res_el.className = 'resultado visible err';
    res_el.textContent = 'Error de conexión.';
  }
}

// ══════════════════════════════════════════════════════════════
// PRESENTADOR
// ══════════════════════════════════════════════════════════════
async function generarPresentacion() {
  const titulo = document.getElementById('presTitle').value.trim();
  const sub    = document.getElementById('presSub').value.trim();
  const raw    = document.getElementById('presSlides').value.trim();
  const tema   = document.getElementById('presTema').value;

  if (!titulo || !raw) { alert('Completa título y slides'); return; }

  const slides = raw.split('\n').filter(Boolean).map(l => {
    const [t, ...rest] = l.split('|');
    return { titulo: t.trim(), contenido: rest.join('|').trim() };
  });

  try {
    const res = await api('/presentador', 'POST', {
      titulo, slides, config: { subtitulo: sub, tema }
    });
    const html = await res.text();
    const w = window.open('', '_blank');
    w.document.write(html);
    w.document.close();
  } catch {
    alert('Error al generar presentación.');
  }
}

// ══════════════════════════════════════════════════════════════
// VIDEO
// ══════════════════════════════════════════════════════════════
async function verPreviewVideo() {
  const titulo   = document.getElementById('vidTitulo').value.trim();
  const tema     = document.getElementById('vidTema').value.trim();
  const duracion = parseInt(document.getElementById('vidDuracion').value) || 60;

  if (!titulo || !tema) { alert('Completa título y tema'); return; }

  try {
    const res = await api('/video/preview', 'POST', { titulo, tema, duracion });
    const html = await res.text();
    const w = window.open('', '_blank');
    w.document.write(html);
    w.document.close();
  } catch {
    alert('Error al generar preview.');
  }
}

async function descargarGuion() {
  const titulo   = document.getElementById('vidTitulo').value.trim();
  const tema     = document.getElementById('vidTema').value.trim();
  const duracion = parseInt(document.getElementById('vidDuracion').value) || 60;

  if (!titulo || !tema) { alert('Completa título y tema'); return; }

  try {
    const res = await api('/video/guion', 'POST', { titulo, tema, duracion });
    const d   = await res.json();
    const blob = new Blob([JSON.stringify(d.guion, null, 2)], { type:'application/json' });
    const url  = URL.createObjectURL(blob);
    const a    = document.createElement('a');
    a.href = url; a.download = `guion_${titulo.replace(/\s+/g,'_')}.json`;
    a.click(); URL.revokeObjectURL(url);
  } catch {
    alert('Error al descargar guión.');
  }
}

// ══════════════════════════════════════════════════════════════
// CONFIG
// ══════════════════════════════════════════════════════════════
async function guardarConfig() {
  const key   = document.getElementById('cfgKey').value.trim();
  const iakey = document.getElementById('cfgIAKey').value.trim();

  if (key) {
    API_KEY = key;
    localStorage.setItem('sofi_key', key);
  }

  try {
    const body = {};
    if (iakey) body.api_key = iakey;
    if (Object.keys(body).length) await api('/config', 'PATCH', body);
    agregarMensaje('Config guardada ✓', 'sistema');
    cambiarPanel('chat', document.querySelector('.nav-btn'));
  } catch {
    alert('Error al guardar config.');
  }
}

async function toggleModo() {
  modoOnline = !modoOnline;
  document.getElementById('cfgModo').textContent = modoOnline ? 'ON' : 'OFF';
  document.getElementById('toggleOnline').classList.toggle('on', modoOnline);
  try {
    await api('/config', 'PATCH', { modo_online: modoOnline });
  } catch {}
}

async function ensenar() {
  const clave     = document.getElementById('aprenClave').value.trim();
  const contenido = document.getElementById('aprenContenido').value.trim();
  const res_el    = document.getElementById('aprenResult');

  if (!clave || !contenido) { alert('Completa clave y contenido'); return; }

  try {
    const res = await api('/conocimiento', 'POST', { clave, contenido });
    const d   = await res.json();
    res_el.className = 'resultado visible ok';
    res_el.textContent = d.msg || 'Aprendido ✓';
    document.getElementById('aprenClave').value    = '';
    document.getElementById('aprenContenido').value = '';
  } catch {
    res_el.className = 'resultado visible err';
    res_el.textContent = 'Error al enseñar.';
  }
}

