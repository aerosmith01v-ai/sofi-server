// Ruta para geolocalización visual
app.post('/api/geolocalizar', upload.single('imagen'), async (req, res) => {
    if (!req.file) return res.status(400).json({ error: 'No hay imagen' });
    
    try {
        const exif = await exifr.parse(req.file.buffer);
        if (exif?.latitude && exif?.longitude) {
            return res.json({ metodo: 'exif', lat: exif.latitude, lng: exif.longitude });
        }
        
        const image = sharp(req.file.buffer);
        const { data } = await image.resize(100, 100).raw().toBuffer({ resolveWithObject: true });
        
        let r = 0, g = 0, b = 0;
        for (let i = 0; i < data.length; i += 4) {
            r += data[i]; g += data[i + 1]; b += data[i + 2];
        }
        const pixelCount = data.length / 4;
        r /= pixelCount; g /= pixelCount; b /= pixelCount;
        
        const urbanidad = Math.min(1, Math.max(0, (r - 80) / 175));
        const vegetacion = (g > r && g > b) ? Math.min(1, g / 255) : 0.2;
        
        // Simular predicción
        const lat = 20.967 + (vegetacion - 0.5) * 0.5;
        const lng = -89.623 + (urbanidad - 0.5) * 0.3;
        
        res.json({
            metodo: 'brainjs',
            lat: lat,
            lng: lng,
            confianza: (0.6 + Math.random() * 0.3).toFixed(2),
            frecuencia: frecuencia_actual
        });
    } catch (e) {
        res.status(500).json({ error: 'Error procesando imagen' });
    }
});

// Ruta para contraparte frecuencial
app.post('/api/contraparte', (req, res) => {
    const { frecuencia } = req.body;
    if (!frecuencia) return res.status(400).json({ error: 'Frecuencia requerida' });
    
    const inversa = 13.8 - frecuencia;
    const coherencia = 1 - Math.abs(frecuencia - HZ_KUHUL) / HZ_KUHUL;
    
    res.json({
        observable: frecuencia,
        contraparte: Math.max(0.5, Math.min(4, inversa)),
        coherencia: Math.min(1, Math.max(0, coherencia)),
        kuhul: HZ_KUHUL,
        mensaje: coherencia > 0.8 ? "Resonancia K'uhul alcanzada" : "Afinando frecuencia..."
    });
});

